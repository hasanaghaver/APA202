@using _26_DynamicPropertiesViewModel.Models
@using _26_DynamicPropertiesViewModel.ViewModels
@model HomeVM
<h1>Home Page</h1>



<ul>
	@foreach (Student item in Model.Students)
	{
		<li>@item.Name, @item.Surname, @item.Id</li>
	}
</ul>

<table border="1">
	@foreach (var teacher in Model.Teachers)
	{
		<tr>
			<td> @teacher.Id</td>
			<td>  @teacher.Name</td>
			<td> @teacher.Salary</td>
		</tr>
	}
</table>